{
  "name": "hero",
  "type": "section",
  "styles": [
    "hero.css"
  ],
  "scripts": [],
  "requires": [
    "ctas",
    "text",
    "image",
    "commons"
  ],
  "fields": {
    "isReverse": { "widget": "checkbox", "label": "Reverse layout (image on the right)", "default": false },
    "isFullScreen": { "widget": "checkbox", "label": "Full-screen hero", "default": false },
    "image": { "$use": "image" },
    "text": { "$use": "text", "titleTag": { "default": "h1" } },
    "ctas": { "$use": "ctas" },
    "date": { "widget": "text", "label": "Date (optional)", "default": "" },
    "author": { "widget": "text", "label": "Author (optional)", "default": "" },
    "$extends": ["commons"]
  },
  "validation": {
    "required": [
      "sectionType"
    ],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "hero"
      },
      "isReverse": {
        "type": "boolean"
      },
      "isFullScreen": {
        "type": "boolean"
      },
      "isDisabled": {
        "type": "boolean"
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "containerFields.noMargin.top": {
        "type": "boolean"
      },
      "containerFields.noMargin.bottom": {
        "type": "boolean"
      },
      "containerFields.noPadding.top": {
        "type": "boolean"
      },
      "containerFields.noPadding.bottom": {
        "type": "boolean"
      },
      "containerFields.background.isDark": {
        "type": "boolean"
      },
      "containerFields.background.imageScreen": {
        "type": "string",
        "enum": [
          "light",
          "dark",
          "none"
        ]
      },
      "text.titleTag": {
        "type": "string",
        "enum": [
          "h1",
          "h2",
          "h3",
          "h4",
          "h5",
          "h6"
        ],
        "default": "h1"
      },
      "ctas": {
        "type": "array",
        "items": {
          "properties": {
            "isButton": {
              "type": "boolean"
            },
            "buttonStyle": {
              "type": "string",
              "enum": [
                "primary",
                "secondary",
                "tertiary",
                "inverted"
              ]
            },
            "isSmall": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}