{
  "name": "flip-card",
  "type": "partial",
  "styles": [
    "flip-card.css"
  ],
  "scripts": [
    "flip-card.js"
  ],
  "requires": [
    "ctas",
    "text",
    "icon",
    "commons"
  ],
  "fields": {
    "front": {
      "icon": {
        "icon": { "widget": "text", "label": "Front icon name", "default": "" },
        "url": { "widget": "text", "label": "Front icon link URL", "default": "" }
      },
      "text": { "$use": "text", "titleTag": { "default": "h3" } },
      "ctas": { "$use": "ctas" }
    },
    "back": {
      "text": { "$use": "text", "titleTag": { "default": "h3" } },
      "ctas": { "$use": "ctas" }
    }
  },
  "validation": {
    "required": [
      "front",
      "back"
    ],
    "properties": {
      "front": {
        "type": "object",
        "properties": {
          "icon": {
            "type": "object",
            "properties": {
              "icon": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            }
          },
          "text": {
            "type": "object"
          },
          "ctas": {
            "type": "array"
          }
        }
      },
      "back": {
        "type": "object",
        "properties": {
          "text": {
            "type": "object"
          },
          "ctas": {
            "type": "array"
          }
        }
      }
    }
  }
}