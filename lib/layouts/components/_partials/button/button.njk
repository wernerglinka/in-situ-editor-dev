{# Call To Actions macro may render multiple button and/or text links #}
{#
  `path` is the in-situ editor's field path to this cta (e.g. "ctas.0"), set only
  in a preview render. When present, the label is wrapped in a data-field span so
  it can be edited in place; otherwise the label renders bare, so production
  output is unchanged.
#}
{% macro button(info, path=null) %}
  {% if info.url %}
    {# Render as anchor link when URL is provided #}
    <a
      class="button {{ info.buttonStyle }}{% if info.isSmall %} small{% endif %}"
      href="{{info.url}}"
      {% if info.url | isExternal %}target="_blank" rel="noopener noreferrer" aria-label="{{ info.label }} (opens in new window)" {% endif %}
      {% if info.ariaLabel %}aria-label="{{ info.ariaLabel }}"{% endif %}
    >
      {% if info.icon %}{% include "icons/" + info.icon + ".njk" %}{% endif %}
      {% if path %}<span data-field="{{ path }}.label">{{ info.label }}</span>{% else %}{{ info.label}}{% endif %}
    </a>
  {% else %}
    {# Render as button element when no URL (for JavaScript actions) #}
    <button
      class="{{ info.buttonStyle }}{% if info.isSmall %} small{% endif %}"
      {% if info.type %}type="{{ info.type }}"{% else %}type="button"{% endif %}
      {% if info.ariaLabel %}aria-label="{{ info.ariaLabel }}"{% endif %}
      {% if info.dataAction %}data-action="{{ info.dataAction }}"{% endif %}
      {% if info.disabled %}disabled{% endif %}
    >
      {% if info.icon %}{% include "icons/" + info.icon + ".njk" %}{% endif %}
      {% if path %}<span data-field="{{ path }}.label">{{ info.label }}</span>{% else %}{{ info.label}}{% endif %}
    </button>
  {% endif %}
{% endmacro %}
